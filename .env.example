# ============================================================
#  LLM providers  (drip.llm — one layer, every provider)
# ============================================================
# Address any model as `provider/model`, e.g.
#   drip bench run --agent openai/gpt-4o
#   drip bench run --agent anthropic/claude-sonnet-4-6
#   drip bench run --agent openrouter/google/gemini-2.0-flash
#   drip doctor --narrate deepseek/deepseek-chat
#
# You only need a key for the providers you actually use. Unknown model
# names fall back to OpenRouter automatically. Run `drip llm` to list all.

# --- Anthropic (Claude) — also the default Drip-Bench judge ---
ANTHROPIC_API_KEY=

# --- OpenAI (GPT / o-series) — also gpt-image-* for the Creative agent ---
OPENAI_API_KEY=

# --- OpenRouter — aggregator + universal fallback router ---
OPENROUTER_API_KEY=

# --- Google Gemini (OpenAI-compatible endpoint) ---
GEMINI_API_KEY=

# --- DeepSeek (V3 / R1) ---
DEEPSEEK_API_KEY=

# --- Alibaba Qwen (DashScope compat mode) ---
DASHSCOPE_API_KEY=

# --- Moonshot (Kimi) ---
MOONSHOT_API_KEY=

# --- xAI (Grok) ---
XAI_API_KEY=

# --- Groq (fast open models) ---
GROQ_API_KEY=

# --- Together (hosted open models) ---
TOGETHER_API_KEY=

# --- Mistral / Codestral ---
MISTRAL_API_KEY=

# --- Local servers (no key; override base URL if non-default) ---
# OLLAMA_BASE_URL=http://localhost:11434/v1
# VLLM_BASE_URL=http://localhost:8000/v1

# ============================================================
#  Video generation
# ============================================================
# Volc Engine ARK — Seedance 2.0 (字节跳动).
# Keys: https://www.volcengine.com/product/ark (CN) or BytePlus ModelArk (intl).
ARK_API_KEY=
SEEDANCE_MODEL=doubao-seedance-2-0-260128

# ============================================================
#  Ad platforms
# ============================================================
# Meta Marketing API access token (long-lived).
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# TikTok Marketing API
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# China platforms (drip.adapters.writers — REST write path, no SDK).
# Reads are sample-only today; writes are gated + audited (快手 endpoint unconfirmed).
TENCENT_ACCESS_TOKEN=
TENCENT_ACCOUNT_ID=
OCEANENGINE_ACCESS_TOKEN=
OCEANENGINE_ADVERTISER_ID=
KUAISHOU_ACCESS_TOKEN=
KUAISHOU_ADVERTISER_ID=

# AppsFlyer (attribution / MMP)
APPSFLYER_API_TOKEN=
APPSFLYER_APP_ID=

# ============================================================
#  Observability
# ============================================================
# Self-hosted Langfuse. Leave blank to disable tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# ============================================================
#  Drip behavior
# ============================================================
# 'shadow' = generate but do not push to ad platforms (safe default)
# 'copilot' = push but require Slack approval per change
# 'autonomous' = push without approval, up to budget caps
DRIP_MODE=shadow

# Hard budget ceiling (USD). Drip refuses to set a daily budget above this.
DRIP_BUDGET_CAP=500

# Max single-step budget change (fraction). A bigger jump is refused — it would
# reset the platform learning phase. 0.5 = ±50%. Used by `drip apply`.
DRIP_MAX_CHANGE_PCT=0.5

# Append-only audit trail for every platform write (real or shadow).
DRIP_AUDIT_PATH=artifacts/audit/writes.jsonl
