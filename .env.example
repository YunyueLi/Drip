# ============ LLM Orchestrator ============
# Required. Used by the Claude Agent SDK supervisor + most workers.
ANTHROPIC_API_KEY=

# ============ Image generation ============
# OpenAI gpt-image-* — used by Creative Worker for keyframes.
OPENAI_API_KEY=

# ============ Video generation ============
# Volc Engine ARK — Seedance 2.0 (字节跳动).
# Get keys at https://www.volcengine.com/product/ark (CN) or BytePlus ModelArk (intl).
ARK_API_KEY=
# Standard quality model id (also: doubao-seedance-2-0-fast-260128 for speed).
SEEDANCE_MODEL=doubao-seedance-2-0-260128

# ============ Ad platforms ============
# Meta Marketing API access token (long-lived).
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# TikTok Marketing API
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# AppsFlyer (attribution / MMP)
APPSFLYER_API_TOKEN=
APPSFLYER_APP_ID=

# ============ Observability ============
# Self-hosted Langfuse. Leave blank to disable tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# ============ Drip behavior ============
# 'shadow' = generate but do not push to ad platforms (safe default)
# 'copilot' = push but require Slack approval per change
# 'autonomous' = push without approval, up to budget caps
DRIP_MODE=shadow

# Hard budget ceiling (USD). Drip will refuse to spend more than this per run.
DRIP_BUDGET_CAP=500
